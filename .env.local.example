# ──────────────────────────────────────────────────────────────
# Demo to Done — environment variables
# Copy this file to ".env.local" and fill in your real values.
# NEVER commit .env.local to git.
# ──────────────────────────────────────────────────────────────

# --- Email delivery (Resend) ---------------------------------
# 1. Create a free account at https://resend.com
# 2. Create an API key at https://resend.com/api-keys
# 3. Paste it below.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# The inbox where new project submissions + contact messages land.
# This is YOUR email — leads will be delivered here.
LEAD_INBOX_EMAIL=fromdemotodone@gmail.com

# The "from" address shown on notification emails.
# For quick testing you can use "onboarding@resend.dev" (Resend's shared
# sender) — but it can ONLY deliver to the email on your Resend account.
# For production, verify your own domain in Resend and use something like
# "Demo to Done <noreply@yourdomain.com>".
EMAIL_FROM=Demo to Done <onboarding@resend.dev>

# --- Site config ---------------------------------------------
# Public URL of the deployed site (used for SEO metadata + sitemap).
NEXT_PUBLIC_SITE_URL=https://demotodone.com
